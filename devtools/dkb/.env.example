# DKB — Kopieren nach devtools/dkb/.env und Werte eintragen (nicht committen).
# chmod 600 devtools/dkb/.env
#
# Test (empfohlen; Kunden-ID = Benutzerkennung wie aktuelle Webapp):
#   python3 devtools/dkb/dkb_fints_test.py              # Kontenliste
#   python3 devtools/dkb/dkb_fints_balance_tx.py        # Saldo + Umsätze (Konto s. unten)
# DKB-App (decoupled): Standard ist Polling (send_tan None), kein zweites Enter.
#   --decoupled-enter = altes Verhalten; --decoupled-poll-sec / --decoupled-timeout-sec anpassbar.
# TAN-Verfahren der Bank (nur wenn Dialog bis BPD durchgeht):
#   python3 devtools/dkb/dkb_fints_test.py --list-tan-mechanisms
#
# Parameter DKB: https://www.dkb.de/fragen-antworten/kann-ich-eine-finanzsoftware-fuers-banking-benutzen
# TAN Nov. 2024: DKB-App (decoupled) / chipTAN. Immoware24: im Bankzugang „bearbeiten“
# TAN-Verfahren „DKB App (SealOne)“ + Medium = Gerät mit DKB-App — siehe
# https://support.immoware24.de/hc/de/articles/22938955128605-Änderungen-der-DKB-bei-FinTS-HBCI
# Kunden-ID = Benutzerkennung (neuer DKB-Server); s. Forum https://homebanking-hilfe.de/forum/topic.php?t=26871
# (In python-fints: Mechanismus-Auswahl beim Bootstrap, oft 940/decoupled.)

FINTS_USER=
FINTS_PIN=
# Konto für dkb_fints_balance_tx.py (mind. IBAN oder Kontonummer)
FINTS_IBAN=
FINTS_BIC=
FINTS_ACCOUNT=
# Alternativ zur Kontonummer (gleiche Bedeutung):
# FINTS_KONTO=
# ZKA-Produktregistrierung (ohne oft HTTP 400): https://www.fints.org/de/hersteller/produktregistrierung
FINTS_PRODUCT_ID=
# Optional: HKVVB „Produktversion“ (max. 5 Zeichen). Ohne Eintrag nutzt dkb_fints_test.py testweise „tst01“.
# FINTS_PRODUCT_VERSION=

FINTS_BLZ=12030000
FINTS_ENDPOINT=https://fints.dkb.de/fints
