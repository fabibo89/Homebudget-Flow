# Entwicklung: SQLite
DATABASE_URL=sqlite+aiosqlite:///./homebudget.db

# Entwicklung mit Postgres (docker compose -f docker-compose.yml -f docker-compose.dev.yml up db)
# DATABASE_URL=postgresql+asyncpg://hb:hb@127.0.0.1:5432/homebudget

# Produktion (Docker): siehe docker-compose.yml
# DATABASE_URL=postgresql+asyncpg://hb:hb@db:5432/homebudget
#
# Produktion mit externem Postgres (docker-compose.prod.yml): gleiches Netz wie der DB-Container,
# Hostname = Name des Postgres-Containers, z. B.:
# DATABASE_URL=postgresql+asyncpg://USER:PASS@plantbot_db:5432/homebudget

JWT_SECRET=generate-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# API-Log-Level: DEBUG, INFO, WARNING, ERROR (Docker: docker compose logs -f api)
LOG_LEVEL=INFO

# Fernet-Schlüssel für PIN in der Datenbank (einmal generieren, geheim halten):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIALS_FERNET_KEY=

# IANA-Zeitzone (Berlin = Mitteleuropa mit Sommerzeit)
APP_TIMEZONE=Europe/Berlin

# Täglicher Bank-Sync zur lokalen Uhrzeit in APP_TIMEZONE, z. B. 06:30
SYNC_CRON_HOUR=6
SYNC_CRON_MINUTE=30

# --- FinTS (Comdirect / DKB) ---
# BLZ, FinTS-User, Endpoint und PIN (verschlüsselt) im Bank-Zugang in der App; Product-ID (ZKA) hier:
FINTS_PRODUCT_ID=
# Optional: Fallback wenn keine PIN in der DB (z. B. FinTS-Test ohne Formular-PIN)
# FINTS_PIN=
# DKB-App (decoupled): Polling mit send_tan(None). Ohne UI-TAN-Kanal muss TIMEOUT_SEC > 0 (Cron/Saldo).
# FINTS_DECOUPLED_POLL_SEC=1
# FINTS_DECOUPLED_TIMEOUT_SEC=180
